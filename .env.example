# ── Metadata database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://querymind:querymind@localhost:5432/querymind

# ── Redis (Celery broker + result backend) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-prod-32-chars-minimum
JWT_ALG=HS256
JWT_EXPIRES_MIN=60

# ── Credential encryption ───────────────────────────────────────────────────
# 32-byte key, base64-encoded. Used to encrypt user-supplied DB connection
# strings at rest before they hit the metadata Postgres.
# generate via: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
QM_MASTER_KEY=

# ── vLLM (local, OpenAI-compatible) ─────────────────────────────────────────
VLLM_ENDPOINT=http://localhost:8000/v1
VLLM_MODEL=google/gemma-3-4b-it
