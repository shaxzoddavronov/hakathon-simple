# QueryMind AI backend — copy to `.env` and fill in real values.
# Never commit a populated `.env` file.

# --- Application metadata DB (Postgres in prod, SQLite for unit tests) ---
DATABASE_URL=postgresql+asyncpg://querymind:querymind@localhost:5432/querymind

# --- Broker / cache for Celery + rate-limit / circuit-breaker state ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# Generate a strong secret, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
JWT_EXPIRES_MIN=60

# --- Credential-at-rest encryption master key (AES-GCM / Fernet) ---
# Must be a url-safe base64-encoded 32-byte key. Generate one of:
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
QM_MASTER_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# --- Local LLM (vLLM, OpenAI-compatible API). External APIs are forbidden. ---
VLLM_ENDPOINT=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# Leave blank for a local vLLM. For a shared/admin-hosted endpoint, set this to
# the API key (token) they gave you. VLLM_ENDPOINT then points at their /v1 URL.
VLLM_API_KEY=
