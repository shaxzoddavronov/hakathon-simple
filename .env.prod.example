# Env for the full-stack Docker deploy (infra/docker-compose.prod.yml).
# Copy to .env at the repo root and fill in the secrets, then:
#   docker compose -f infra/docker-compose.prod.yml up -d --build

# --- Secrets (required — compose errors out if unset) ---
# AES-GCM master key for credential-at-rest. Url-safe base64, 32 bytes:
#   python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
QM_MASTER_KEY=
# JWT signing secret (any long random string).
JWT_SECRET=

# --- Model endpoint ---
# Host-run vLLM:        http://host.docker.internal:8000/v1
# Admin shared endpoint: https://<admin-host>/v1   (then set VLLM_API_KEY)
VLLM_ENDPOINT=http://host.docker.internal:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
VLLM_API_KEY=

# --- Optional overrides (sane defaults exist) ---
# POSTGRES_DB=querymind
# POSTGRES_USER=querymind
# POSTGRES_PASSWORD=querymind
# API_PORT=8080
# FRONTEND_PORT=3000
# Must be the URL the BROWSER uses for the API (baked into the frontend at build):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
